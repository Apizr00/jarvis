# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your personal Telegram user ID (get it from @userinfobot)
TELEGRAM_OWNER_ID=your_telegram_user_id_here

# ─── DeepSeek API ───────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── PostgreSQL ─────────────────────────────────────────────
DATABASE_URL=postgresql://jarvis:yourpassword@localhost:5432/jarvisdb

# ─── Redis (optional — facts cache, fallback disabled if unavailable) ──
REDIS_URL=redis://localhost:6379

# ─── App ────────────────────────────────────────────────────
PORT=3000
# Your timezone (e.g. Asia/Kuala_Lumpur, Asia/Singapore, UTC)
TIMEZONE=Asia/Kuala_Lumpur
