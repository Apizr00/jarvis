# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your personal Telegram user ID (get it from @userinfobot)
TELEGRAM_OWNER_ID=your_telegram_user_id_here

# ─── DeepSeek API (primary) ──────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── Xiaomi MiMo API (backup fallback) ──────────────────────
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# ─── PostgreSQL ─────────────────────────────────────────────
DATABASE_URL=postgresql://jarvis:yourpassword@localhost:5432/jarvisdb

# ─── Redis (optional — facts cache, fallback disabled if unavailable) ──
REDIS_URL=redis://localhost:6379

# ─── App ────────────────────────────────────────────────────
PORT=3000
# Your timezone (e.g. Asia/Kuala_Lumpur, Asia/Singapore, UTC)
TIMEZONE=Asia/Kuala_Lumpur
# Morning briefing time in 24h format (default: 7:00)
MORNING_BRIEFING_TIME=7:00

# ─── OpenAI Whisper (optional — for voice message transcription) ──
# Get an API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
# Force a specific language or leave unset for auto-detect (e.g. "ms", "en")
# Auto-detect handles mixed Malay + English well by default.
WHISPER_LANGUAGE=
# Optional prompt hint for mixed-language or domain-specific audio
# WHISPER_PROMPT=English and Bahasa Malaysia mixed conversation

# ─── Weather (optional — for morning briefing) ──────────────
# Free API key from https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here
# City name (e.g. "Kuala Lumpur" or "Kuala Lumpur,MY")
WEATHER_LOCATION=Kuala Lumpur

# ─── Tavily Search (optional — web search for real-time info) ──
# Free tier: 1,000 searches/month. Get key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here
