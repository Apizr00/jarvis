# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your personal Telegram user ID (get it from @userinfobot)
TELEGRAM_OWNER_ID=your_telegram_user_id_here

# ─── ILMU by YTL AI Labs (primary for fast/BM chat) ──────────
# Malaysia's sovereign AI — cheapest & best for Bahasa Melayu
# Get your API key at https://console.ilmu.ai
ILMU_API_KEY=your_ilmu_api_key_here
ILMU_BASE_URL=https://api.ilmu.ai
ILMU_MODEL=ilmu-mini-v3.3

# ─── DeepSeek API (deep reasoning & tool execution) ──────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── Xiaomi MiMo API (backup fallback) ──────────────────────
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# ─── PostgreSQL ─────────────────────────────────────────────
DATABASE_URL=postgresql://jarvis:yourpassword@localhost:5432/jarvisdb

# ─── Redis (optional — facts cache, fallback disabled if unavailable) ──
REDIS_URL=redis://localhost:6379

# ─── App ────────────────────────────────────────────────────
# Your bot's display name (used in system prompt & banner)
BOT_NAME=Jarvis
PORT=3000
# Your timezone (e.g. Asia/Kuala_Lumpur, Asia/Singapore, UTC)
TIMEZONE=Asia/Kuala_Lumpur
# Morning briefing time in 24h format (default: 7:00)
MORNING_BRIEFING_TIME=7:00
# Daily reflection time in 24h format (default: 21:00)
REFLECTION_TIME=21:00
# Weekly review time (Sunday) in 24h format (default: 10:00)
WEEKLY_REVIEW_TIME=10:00

# ─── OpenAI Whisper (optional — for voice message transcription) ──
# Get an API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
# Force a specific language or leave unset for auto-detect (e.g. "ms", "en")
# Auto-detect handles mixed Malay + English well by default.
WHISPER_LANGUAGE=
# Optional prompt hint for mixed-language or domain-specific audio
# WHISPER_PROMPT=English and Bahasa Malaysia mixed conversation

# ─── Weather (optional — for morning briefing) ──────────────
# Free API key from https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here
# City name (e.g. "Kuala Lumpur" or "Kuala Lumpur,MY")
WEATHER_LOCATION=Kuala Lumpur

# ─── Prayer Times — JAKIM e-Solat ──────────────────────────
# Zone code for your location (default: WLY01 = Kuala Lumpur & Putrajaya)
# See src/api/prayertimes.js → ZONES for the full list
PRAYER_ZONE=WLY01
# How long to cache prayer times before re-fetching (ms, default: 5 min)
PRAYER_CACHE_TTL_MS=300000
# API request timeout (ms, default: 10s)
PRAYER_REQUEST_TIMEOUT_MS=10000

# ─── Tavily Search (optional — web search for real-time info) ──
# Free tier: 1,000 searches/month. Get key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: Customize your bot's personality and tone. Use emojis, slang, or formal language as desired.
BOT_PERSONALITY=
