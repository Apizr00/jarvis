# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your personal Telegram user ID (get it from @userinfobot)
TELEGRAM_OWNER_ID=your_telegram_user_id_here

# ─── DeepSeek API (primary) ──────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── Xiaomi MiMo API (backup fallback) ──────────────────────
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# ─── PostgreSQL ─────────────────────────────────────────────
DATABASE_URL=postgresql://jarvis:yourpassword@localhost:5432/jarvisdb

# ─── Redis (optional — facts cache, fallback disabled if unavailable) ──
REDIS_URL=redis://localhost:6379

# ─── App ────────────────────────────────────────────────────
PORT=3000
# Your timezone (e.g. Asia/Kuala_Lumpur, Asia/Singapore, UTC)
TIMEZONE=Asia/Kuala_Lumpur
# Morning briefing time in 24h format (default: 8:00)
MORNING_BRIEFING_TIME=8:00

# ─── Weather (optional — for morning briefing) ──────────────
# Free API key from https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here
# City name (e.g. "Kuala Lumpur" or "Kuala Lumpur,MY")
WEATHER_LOCATION=Kuala Lumpur
